{
  "name": "@k-jadeja/featurebase-mcp",
  "version": "1.0.0",
  "description": "MCP server for the itsremalt Featurebase feedback board (no auth required, reverse-engineered from public board's __NEXT_DATA__)",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "featurebase-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "mcp",
    "featurebase",
    "feedback",
    "itsremalt",
    "model-context-protocol"
  ],
  "author": "K-Jadeja",
  "license": "MIT"
}